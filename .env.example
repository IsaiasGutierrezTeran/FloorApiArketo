# ---- Server ----
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ---- Detector selection: mock | maskrcnn | opencv ----
DETECTOR=mock
MODEL_NAME=maskrcnn-resnet101
WEIGHTS_PATH=weights/maskrcnn_floorplan.h5

# Retry with the classical OpenCV detector when the primary fails / finds 0
# walls / has mean wall confidence below CONFIDENCE_THRESHOLD.
FALLBACK_TO_OPENCV=false

# ---- Legacy Mask R-CNN service (used when DETECTOR=maskrcnn) ----
# The original FloorPlanTo3D Flask API (Python 3.6 / TF 1.15) running elsewhere.
LEGACY_API_URL=http://127.0.0.1:5000/
LEGACY_API_TIMEOUT=120
LEGACY_DEFAULT_CONFIDENCE=0.99

# ---- Inference defaults (overridable per request) ----
CONFIDENCE_THRESHOLD=0.5
WALL_HEIGHT=2.7
DEFAULT_WALL_THICKNESS=0.15
DOOR_HEIGHT=2.1
WINDOW_HEIGHT=1.1
WINDOW_SILL_HEIGHT=0.9

# ---- OpenCV (classical) detector parameters ----
OPENCV_MIN_WALL_LENGTH_PX=40
OPENCV_HOUGH_THRESHOLD=80
OPENCV_HOUGH_MIN_LINE_LENGTH=50
OPENCV_HOUGH_MAX_LINE_GAP=10
OPENCV_MERGE_DISTANCE_PX=10

# ---- Image limits ----
MAX_IMAGE_SIZE_MB=10
MAX_IMAGE_DIMENSION=4096

# ---- CORS (comma-separated origins, or * for all) ----
CORS_ORIGINS=*
